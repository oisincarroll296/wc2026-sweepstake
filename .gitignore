# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── Virtual environment ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Streamlit secrets ────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Personal data ─────────────────────────────────────────────────────────────
# These lines keep personal data OUT of a PUBLIC repo.
# If you are deploying from a PRIVATE repo (recommended for Streamlit Cloud),
# delete or comment out this entire block so the data files are committed
# and the live dashboard has real scores.
data/purchases.csv
data/player_status.csv
data/predictions.csv
data/captains.csv
data/audit_log.csv
data/events.csv
data/allocation.csv
data/payment_ledger.csv
data/*_lock.txt

# ── Claude Code local settings ───────────────────────────────────────────────
.claude/

# ── Generated exports ────────────────────────────────────────────────────────
exports/

# ── Simulation results (generated, can be large) ────────────────────────────
simulations/results/

# ── Streamlit run logs ───────────────────────────────────────────────────────
streamlit_out.txt
streamlit_err.txt

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
