# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── Virtual environment ──────────────────────────────────────────────────────
.venv/
venv/
env/

